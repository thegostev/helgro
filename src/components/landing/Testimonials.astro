---
// Astro
import { Image } from "astro:assets";
// Images
import davidAvatar from "@/images/testimonials/david.png";
import emilyAvatar from "@/images/testimonials/emily.png";
import lisaAvatar from "@/images/testimonials/lisa.png";
import michaelAvatar from "@/images/testimonials/michael.png";
import robertAvatar from "@/images/testimonials/robert.png";
import saraAvatar from "@/images/testimonials/sara.png";
import adamAvatar from "@/images/testimonials/adam.jpeg";
import albertAvatar from "@/images/testimonials/albert.jpeg";
import linkedinLogo from "@/images/testimonials/LI-In-Bug.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";
// Icons
import ArrowLeft from "@/components/fundations/icons/ArrowLeft.astro";
import ArrowRight from "@/components/fundations/icons/ArrowRight.astro";

const testimonials = [
  {
    quote:
      "I'm living in Gdańsk all my life, still Alex is able to surprise me with a new toponym or historical fact about the city.",
    author: "Adam Gadomski",
    role: "Product Manager from Gdańsk",
    avatar: adamAvatar,
    linkedin: "https://www.linkedin.com/in/adam-gadomski/",
  },
  {
    quote:
      "Countless times we travered across Tricity from Wejherowo to the Old Town. Alex is a good companion - eager for discovery!",
    author: "Albert Szubartowski",
    role: "Physiotherapist from Gdynia",
    avatar: albertAvatar,
    linkedin: "https://www.linkedin.com/in/albert-szubartowski-711867320/",
  },
];
---

<section class="overflow-hidden">
  <Wrapper variant="paddingless" class="py-12">
    <div
      class="grid grid-cols-1 lg:grid-cols-3 items-start gap-y-4 xl:ml-8 gap-4"
    >
      <div
        class="order-last p-4 xl:p-8 lg:bg-white lg:rounded-2xl justify-between flex flex-col h-full lg:order-first max-w-screen lg:h-[calc(100vh-8rem)]"
      >
        <div>
          <Text
            tag="h2"
            variant="textXL"
            class="text-base-900 mt-4 text-balance font-medium"
          >
            What other locals (from Gdańsk, Sopot, Gdynia) think about me
          </Text>
        </div>
        <div class="flex items-center gap-4 mt-8">
          <Button
            size="sm"
            variant="muted"
            iconOnly
            aria-label="Previous testimonial"
            id="testimonials-previous"
          >
            <ArrowLeft size="base" slot="icon" />
          </Button>
          <Button
            size="sm"
            variant="muted"
            iconOnly
            aria-label="Next testimonial"
            id="testimonials-next"
          >
            <ArrowRight size="base" slot="icon" />
          </Button>
        </div>
      </div>
      <div
        id="testimonials-slider"
        class="keen-slider lg:col-span-2 pl-4 lg:pl-0 h-full"
      >
        {
          testimonials.map((testimonial) => (
            <div class="keen-slider__slide h-full flex flex-col justify-between rounded-2xl h-full overflow-hidden bg-white p-8">
              <blockquote>
                <span aria-hidden="true" class="text-9xl italic">
                  "
                </span>
                <Text
                  tag="p"
                  variant="displayMD"
                  class="text-base-900 font-medium tracking-tight italic"
                >
                  {testimonial.quote}
                </Text>
              </blockquote>
              <div class="flex items-center gap-2  mt-12 lg:mt-24">
                <Image
                  src={testimonial.avatar}
                  alt={`${testimonial.author} avatar`}
                  class="size-12 rounded-full object-cover "
                />
                <div>
                  <div class="flex items-center gap-1.5">
                    <Text
                      tag="p"
                      variant="textLG"
                      class="text-base-900 font-medium"
                    >
                      {testimonial.author}
                    </Text>
                    <a
                      href={testimonial.linkedin}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${testimonial.author} on LinkedIn`}
                    >
                      <Image
                        src={linkedinLogo}
                        alt="LinkedIn"
                        class="h-[1em] w-auto"
                      />
                    </a>
                  </div>
                  <Text tag="p" variant="textSM" class="text-base-600">
                    {testimonial.role}
                  </Text>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
