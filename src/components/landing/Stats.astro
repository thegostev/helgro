---
// Assets
import { Image } from "astro:assets";
import Team from "@/images/assets/team.png";
// Fundations
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Text from "@/components/fundations/elements/Text.astro";

const stats = [
  {
    number: "4-6",
    label:
      "4-6 morning walks/week is one of the modes how I explore Gdańsk on foot.",
  },
  {
    number: "5",
    label:
      "I'm using 5 languages on a weekly basis: English for work; Ukrainian for friends and family; Norwegian for to do's and comments; russian at home; Polish in the city.",
  },
  {
    number: "15+",
    label:
      "15+ craft beer venues visited across Tricity (with specific tap counts: Pułapka - 13, Labeerynt - 10).",
  },
  {
    number: "20+",
    label:
      "20+ Tricity districts personally assessed with qualitative notes (Piecki-Migowo, Siedlce, Brętowo, Jaśień, Oliwa, Wrzeszcz, Orłowo, Przymorze Małe, Gdynia center, Old City, Young City, Działki Lesne, Leszczynki, Jelitkowo, Kamienny Potok, etc.).",
  },

];
---

<section>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div>
        <div class="lg:sticky lg:top-24 max-w-sm">
          <Image
            src={Team}
            alt="Team"
            width={800}
            height={1080}
            loading="eager"
            decoding="async"
            class="object-cover aspect-square rounded-xl"
          />
          <Text
            tag="p"
            variant="textSM"
            class="text-base-600 mt-4 text-balance font-medium"
          >
            Hey! Nice to know that you're reading. Few facts about me.
          </Text>
        </div>
      </div>
      <div class="lg:col-span-2">
        <Text
          tag="p"
          variant="displaySM"
          class="text-base-900 font-medium tracking-tight"
        >
          At my core is a belief that the best travel happens through people,
          not itineraries. Every recommendation, every hidden spot, every
          unexpected detour, it all matters. When you explore with me,
          you’re getting a local who’s invested in helping you make the
          most out of your weekend.
        </Text>
        <Text tag="p" variant="textBase" class="text-base-600 mt-8">
          I’m not a tour guide - I’m a local who loves showing people around.
          I blend insider knowledge with genuine curiosity about what makes
          each visitor tick. Whether it’s a weekend escape, a food crawl,
          or just wandering the backstreets, the goal is always the same: to
          make the Tricity feel like yours.
        </Text>
        <div class="divide-y divide-base-200 border-y border-base-200 mt-8">
          {
            stats.map((stat) => (
              <div class="grid grid-cols-1 lg:grid-cols-3 items-start gap-4 pb-8 pt-8 lg:sticky lg:top-0 bg-base-100">
                <Text
                  tag="p"
                  variant="display2XL"
                  class="text-base-900 font-semibold  italic"
                >
                  {stat.number}
                </Text>
                <Text
                  tag="p"
                  variant="textBase"
                  class="text-base-600 lg:col-span-2 text-balance"
                >
                  {stat.label}
                </Text>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
