---
// Assets
import { Image } from "astro:assets";
import one from "@/images/services/1.png";
import two from "@/images/services/2.png";
import three from "@/images/services/3.png";
import implementationImg from "@/images/services/4.png";
import five from "@/images/services/5.png";
import six from "@/images/services/6.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const processSteps = [
  {
    title: "Pick a weekend",
    description:
      "Check flights to Gdańsk Airport (book 2+ weeks ahead; expect €30-80 round trip from Copenhagen, Stockholm, or Oslo).",
    image: one,
  },
  {
    title: "Book your time with me",
    description:
      "Book the weekend using the calendar below. Or, drop me a message, call, or text to lock in your dates.",
    image: two,
  },
  {
    title: "Book a hotel",
    description:
      "I'm usually using AirBnb, Booking.com or Trivago to check options.",
    image: three,
  },
  {
    title: "Pack light ",
    description:
      "One backpack is enough for 2-3 nights, no checked luggage needed. But, you know what you need better than me.",
    image: implementationImg,
  },
  {
    title: "Land in Gdańsk",
    description:
      "I pick you up at the airport (for arrivals after 18:00) or meet you in the city, your choice.",
    image: five,
  },
  {
    title: "Explore with me, then on your own",
    description:
      "Saturday and Sunday you get 5 hours of guided experience each day, plus curated tips for the rest.",
    image: six,
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div>
        <div
          class="p-8 bg-white rounded-xl lg:sticky lg:top-24 max-w-sm flex flex-col"
        >
          <Kicker copy="The Process" />
          <Text
            tag="h3"
            variant="textXLG"
            class="text-base-900 text-balance mt-12 font-medium"
          >
            Easier than booking an IKEA delivery.
          </Text>
        </div>
      </div>
      <div
        class="lg:col-span-2 divide-y divide-base-200 border-y border-base-200"
      >
        {
          processSteps.map((step, index) => (
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4 py-8 lg:sticky lg:top-0 bg-base-100">
              <Text
                tag="p"
                variant="display2XL"
                class="text-base-900 font-semibold  italic"
              >
                0{index + 1}.
              </Text>
              <div class="lg:col-span-2 text-balance">
                <Text
                  tag="h3"
                  variant="displaySM"
                  class="text-base-900 font-medium tracking-tight lg:text-balance"
                >
                  {step.title}
                </Text>
                <Text tag="p" variant="textSM" class="text-base-600 mt-2">
                  {step.description}
                </Text>
              </div>
              <Image
                src={step.image}
                alt={step.title}
                width={500}
                height={273}
                loading="lazy"
                decoding="async"
                class="w-full h-48 object-cover rounded-xl"
              />
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
